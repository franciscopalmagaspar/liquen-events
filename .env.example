# ───────────────────────────────────────────────────────────────
# Líquen Events — variáveis de ambiente
# Copie para ".env.local" (desenvolvimento) ou defina no Vercel
# (Settings → Environment Variables) em produção.
# ───────────────────────────────────────────────────────────────

# ── Envio de e-mails (formulário de contacto + orçamentos) ──
# Exemplo para Gmail: criar uma "Palavra-passe de app" em
# https://myaccount.google.com/apppasswords (requer verificação em 2 passos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=o-seu-email@gmail.com
SMTP_PASS=palavra-passe-de-app-de-16-digitos

# Para onde chegam os pedidos (opcional — por defeito: liquen.alentejo@gmail.com)
MAIL_TO=liquen.alentejo@gmail.com
# Remetente (opcional — por defeito: SMTP_USER)
MAIL_FROM=o-seu-email@gmail.com

# ── Inbox (ler e-mails recebidos no dashboard, via IMAP) ──
# No Gmail use a mesma palavra-passe de app. Por defeito usa os valores SMTP_*.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=o-seu-email@gmail.com
IMAP_PASS=palavra-passe-de-app-de-16-digitos

# ── Base de dados (Supabase) ──
# Crie um projeto grátis em https://supabase.com, corra o db/schema.sql,
# e copie de Settings → API:
SUPABASE_URL=https://xxxxxxxx.supabase.co
# A chave "service_role" (secreta) — NUNCA a exponha no cliente:
SUPABASE_SERVICE_ROLE_KEY=ey...service-role-key...

# ── Painel de administração (/orcamento/admin) ──
# Segredo para assinar as sessões (OBRIGATÓRIO em produção).
# Gere uma string aleatória de 32+ caracteres, ex.: openssl rand -base64 32
SESSION_SECRET=

# Password partilhada — guarde o HASH bcrypt, nunca a password em texto.
# Gere com: node -e "console.log(require('bcryptjs').hashSync('A_SUA_PASS',10))"
ADMIN_PASSWORD_HASH=

# (Opcional) Contas individuais por sócio, em JSON. Substitui a password
# partilhada. Cada hash é gerado como acima.
# ADMIN_USERS=[{"name":"Catarina","passwordHash":"$2b$10$..."}]

# Nome mostrado no back office (saudação) — opcional
ADMIN_NAME=Catarina

# ── URL público do site (para as páginas de confirmação em dev) ──
# Em produção o Vercel trata disto; pode deixar em branco.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── SEO ──
# Código de verificação do Google Search Console (opcional)
GOOGLE_SITE_VERIFICATION=

# ── Notificações push (Web Push) ──
# Gere uma vez com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:liquen.alentejo@gmail.com

# ── Resumo diário automático (cron) ──
# Protege o endpoint /api/cron/reminders. O Vercel Cron envia este valor
# automaticamente como Bearer token. Use uma string longa e aleatória.
CRON_SECRET=
