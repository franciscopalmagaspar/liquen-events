# ───────────────────────────────────────────────────────────────
# Líquen Events — variáveis de ambiente
# Copie para ".env.local" (desenvolvimento) ou defina no Vercel
# (Settings → Environment Variables) em produção.
# ───────────────────────────────────────────────────────────────

# ── Envio de e-mails (formulário de contacto + orçamentos) ──
# Exemplo para Gmail: criar uma "Palavra-passe de app" em
# https://myaccount.google.com/apppasswords (requer verificação em 2 passos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=o-seu-email@gmail.com
SMTP_PASS=palavra-passe-de-app-de-16-digitos

# Para onde chegam os pedidos (opcional — por defeito: liquen.alentejo@gmail.com)
MAIL_TO=liquen.alentejo@gmail.com
# Remetente (opcional — por defeito: SMTP_USER)
MAIL_FROM=o-seu-email@gmail.com

# ── Painel de administração de orçamentos ──
# Password para aceder a /orcamento/admin (mude para algo seguro)
ADMIN_PASSWORD=defina-uma-password-segura

# ── URL público do site (para as páginas de confirmação em dev) ──
# Em produção o Vercel trata disto; pode deixar em branco.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
